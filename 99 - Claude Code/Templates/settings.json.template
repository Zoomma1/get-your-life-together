{
  "permissions": {
    "allow": [
      "Read({{VAULT_PATH}}/*)",
      "Write({{VAULT_PATH}}/99 - Claude Code/*)"
    ],
    "additionalDirectories": [
      "{{VAULT_PATH}}"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{CLAUDE_HOME}}/hooks/recap-session.js\"",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{CLAUDE_HOME}}/hooks/retention-purge.js\"",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{CLAUDE_HOME}}/hooks/secret-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "effortLevel": "high"
}
